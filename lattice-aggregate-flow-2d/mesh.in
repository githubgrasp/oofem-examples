# 2D node distribution: 100x100 mm rectangle with circular inclusions
# loaded from packing.dat (disks from `aggregate`). Non-periodic.
#@output mesh.nodes
#@domain 2
#@diam 0.002
#@maxiter 100000
#@ranint -1
#@perflag 2 0 0
#@ranflag 1
#@vertex 1 coords 2 -0.005 -0.005 refine 1. radius 0.
#@vertex 2 coords 2  0.105  0.105 refine 1. radius 0.
#@rect 1 box 4 0. 0. 0.1 0.1 refine 1.
#@inclusionfile packing.dat itz 1.e-9 refine 0.5
